# -----------------------------------------------
# Quick local dev setup (SQLite, no PostgreSQL):
#
#   cp .env.example .env
#   pip install -r requirements.txt
#   python manage.py migrate
#   python manage.py createsuperuser
#   python manage.py runserver
#
# For production / Docker, set USE_SQLITE=False
# and configure the DB_* variables below.
# -----------------------------------------------

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Use SQLite for local dev (no PostgreSQL needed)
USE_SQLITE=True

# PostgreSQL settings (only used when USE_SQLITE=False)
DB_NAME=nfl_squares
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# Site URL — used to build clickable links in invite emails
# Local WiFi: use your Mac's LAN IP  (ipconfig getifaddr en0)
# Production: your public domain
SITE_URL=http://localhost:8000

# Email — Gmail example (generate an App Password at myaccount.google.com/apppasswords)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=NFL Squares <your@gmail.com>

# Tip: for local testing without sending real email, use the console backend:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
