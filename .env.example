# -----------------------------------------------
# Quick local dev setup (SQLite, no PostgreSQL):
#
#   cp .env.example .env
#   pip install -r requirements.txt
#   python manage.py migrate
#   python manage.py createsuperuser
#   python manage.py runserver
#
# For production / Docker, set USE_SQLITE=False
# and configure the DB_* variables below.
# -----------------------------------------------

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Use SQLite for local dev (no PostgreSQL needed)
USE_SQLITE=True

# PostgreSQL settings (only used when USE_SQLITE=False)
DB_NAME=nfl_squares
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
