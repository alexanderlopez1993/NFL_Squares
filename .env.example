# -----------------------------------------------
# Quick local dev setup (SQLite, no PostgreSQL):
#
#   cp .env.example .env
#   pip install -r requirements.txt
#   python manage.py migrate
#   python manage.py createsuperuser
#   python manage.py runserver
#
# For production / Docker, set USE_SQLITE=False
# and configure the DB_* variables below.
# -----------------------------------------------

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# Include .trycloudflare.com only for short Cloudflare Tunnel test shares.
ALLOWED_HOSTS=localhost,127.0.0.1,.trycloudflare.com

# Use SQLite for local dev (no PostgreSQL needed)
USE_SQLITE=True

# PostgreSQL settings (only used when USE_SQLITE=False)
DB_NAME=nfl_squares
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# Public app URL used when generating invite links and OAuth callbacks.
SITE_URL=http://localhost:8000

# Google OAuth for admin login.
# Google Console redirect URI:
#   http://localhost:8000/accounts/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# OAuth users must match an existing staff user's email or these allowlists.
# Use comma-separated emails/domains, for example:
#   ADMIN_OAUTH_STAFF_EMAILS=you@example.com,partner@example.com
#   ADMIN_OAUTH_STAFF_DOMAINS=example.com
ADMIN_OAUTH_STAFF_EMAILS=
ADMIN_OAUTH_STAFF_DOMAINS=
ADMIN_OAUTH_SUPERUSER_EMAILS=

# Email invites. For local testing, use the console backend.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=NFL Squares <noreply@example.com>
